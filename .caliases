
alias kb 'setxkbmap -layout ie -option ctrl:nocaps'
alias kbr 'setxkbmap -layout ie -option caps:swapescape'

# no print after cd
unalias cwdcmd

# default options for common commands
alias cp 'cp -i'
alias grep 'grep --color'
alias ls 'ls --color=auto --indicator-style=slash'
alias diff 'diff --color'
alias tree 'tree -a -I ".git|.venv|__pycache__|.idea|.~lock.*"'
alias ncdu 'ncdu --disable-shell --disable-delete --color off'
alias fzf 'fzf --border --layout reverse --height 40%'

# typing makes me tired
alias l 'ls -1'
alias ll 'ls -lh'
alias la 'ls -1A'
alias lsa 'ls -A'
alias lla 'ls -lhA'
alias lal 'ls -lhA'
alias hg 'history | head -n -1 | grep -i'
alias hist 'history | fzf --border --layout reverse --height 40%'
alias nv 'nvim'
alias cdl 'cd `ls -t -d */ | head -1`'

# custom scripts / functions / "complex aliases"
alias bkm "pwd >> $DIR_BOOKMARKS && sort --unique --output $DIR_BOOKMARKS $DIR_BOOKMARKS"
alias cdf 'cd `furthest-path \!*`'
alias m 'mkdir `date "+%Y-%m-%d_"\!*`'
alias g 'cd `go_bookmarked.tcsh \!*`'
alias d 'dirs -S $DIR_STACK_FILE && cd `go_history.tcsh \!*`'
alias p 'cd `go_parents.tcsh \!*`'

# comparing and copying directories and files
alias cpr "rsync --recursive --copy--links --chmod=ug=rwX --exclude-from=$HOME/.exclude_patterns"
alias nvd 'nvim -d'
alias nvpd 'nvim -c "set filetype=diff"'
alias diffu 'diff --unified'
alias diffr "diff --recursive --exclude-from=$HOME/.exclude_patterns"
alias diffrb "diff --recursive --exclude-from=$HOME/.exclude_patterns --brief"
alias diffru "diff --recursive --exclude-from=$HOME/.exclude_patterns --unified"

# /* vim: set filetype=tcsh : */
