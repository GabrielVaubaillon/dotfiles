# Adding personal programs and scripts to PATH
set path = ($HOME/bin $HOME/scripts $path)

# KEYS
# ----

# Del
bindkey "^[[3~" delete-char # use CTRL-D

# ^Del and ^Backspace
bindkey "^[[3;5~" delete-word # use ALT-D
bindkey "^H" backward-delete-word # use CTRL-W

# ^-Left and ^-Right
bindkey "^[[1;5D" backward-word # use ALT-B
bindkey "^[[1;5C" backward-word # use ALT-F

# ^W only delete a word
bindkey "^W" backward-delete-word

# MISC
# ----

# No beep
set nobeep

# > cannot overwrite a file. You have to do >!
set noclobber

# Do not exit on end-of-file.  Require the use of exit or logout instead.
# However,  ten  consecutive EOFs will cause the shell to exit anyway,
# to avoid the shell hanging if its tty goes away.
set ignoreeof = '10'

# report status of job asynchronously
set notify

# HISTORY
# -------

set histfile="$HOME/.tcsh_history"
set history=10000
set savehist=(10000 merge)

# expand in history
set autoexpand

# COMPLETION
# ----------

# Show possible completions
set autolist

# Case insensitive completion
set complete = 'igncase'

# FILESYSTEM NAVIGATION
# ---------------------
alias cd "pushd"
# Do not store duplicates in the stack.
set dunique
# Do not print the directory stack after pushd or popd.
set pushdsilent
# pushd without args go to home
set pushdtohome

setenv DIR_STACK_FILE "$HOME/.dir_stack_tmp"
setenv DIR_BOOKMARKS "$HOME/.dir_bookmarks"
if ( ! -f $DIR_BOOKMARKS ) then
    touch $DIR_BOOKMARKS
endif

# PROMPT
# ------
set green = "%{\033[1;32m%}"
set blue = "%{\033[1;34m%}"
set end = "%{\033[0m%}"
# set prompt = "╭─%B[tcsh]${green}%n@%M:${blue}%~/\n%b╰─%B▶${reset} "
set prompt = "╭─%B[tcsh]${green}%n@%M:${blue}%~/%b\n${end}╰─%B▶%b "

# ALIASES
# -------

alias 'reload' 'source $HOME/.tcshrc'
# tcsh alias are not the same as bash and zsh, need to do a little sed magic
source "$HOME/.caliases"

